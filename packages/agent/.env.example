# AI Model Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here  # Optional alternative

# MCP Server Connection
MCP_SERVER_URL="http://localhost:8000"
MCP_SERVER_TIMEOUT=30

# Agent Configuration  
DEFAULT_LLM=openai  # or 'anthropic'
LOG_LEVEL=INFO
ENABLE_MEMORY=true

# User Preferences (Customize these!)
USER_NAME=Kevin
USER_LOCATION=San Francisco
DEFAULT_COMMUTE_ORIGIN=Home
DEFAULT_COMMUTE_DESTINATION=Office

# Development
DEBUG=false
ENVIRONMENT=development

# ----- Auth: enforced when INTERNAL_AUTH_SECRET is set -----
# Comma-separated Google emails the Agent will accept. Requests without an
# allowlisted X-User-Email header (set by the UI proxy) are rejected.
ALLOWED_EMAILS=you@example.com

# Shared secret with the UI. The UI sends this in X-Internal-Auth on every
# Agent call; the Agent rejects anything that doesn't match.
# Generate with: openssl rand -hex 32
INTERNAL_AUTH_SECRET=replace_me_with_a_long_random_string
