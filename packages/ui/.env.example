# Environment Variables for Daily Agent UI

# AI Agent API URL
# For local development: http://localhost:8001
# For production: https://your-deployed-ai-agent-url.railway.app
VITE_AI_AGENT_API_URL=http://localhost:8001

# Environment identifier (development, staging, production)
VITE_ENVIRONMENT=development

# Optional: Enable debug mode (true/false)
VITE_DEBUG=true

# ----- Auth: Google OAuth + single-user allowlist -----
# Comma-separated list of Google emails permitted to sign in.
ALLOWED_EMAILS=you@example.com

# Google OAuth 2.0 credentials. Create at:
# https://console.cloud.google.com/apis/credentials
# (Application type: Web application)
# Authorized redirect URIs must include {origin}/auth/google/callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# REQUIRED in production (or any deployment behind a TLS-terminating proxy
# like Vercel/Cloudflare/nginx). In dev it's auto-derived from the request.
# The app fails fast at first /auth/google hit if unset in production.
# GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_long_random_string

# Shared secret with the Agent. Generate with: openssl rand -hex 32
INTERNAL_AUTH_SECRET=replace_me_with_a_long_random_string

# Session cookie Secure flag. Defaults to true (Secure). Set to "false" only
# for local HTTP dev — every other env (preview/staging/prod) should leave
# this unset so the cookie is never sent over plaintext.
# SESSION_COOKIE_SECURE=false

# Note: For Vercel deployment, set these in the Vercel dashboard:
# https://vercel.com/\[your-username\]/\[your-project\]/settings/environment-variables
