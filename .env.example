# ================================
# MCP Server     
# ================================
# External API Keys (Required)
WEATHER_API_KEY=your_openweathermap_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Optional integrations
GOOGLE_CALENDAR_CREDENTIALS_PATH=./google_calendar_credentials.json
TODOIST_API_KEY=your_todoist_api_key

# Weekend Orchestrator
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key
OUTDOORACTIVE_API_KEY=your_outdooractive_api_key  # Optional, falls back to Google Places

# Personal Addresses for Accurate Commute Routing 🚗🚂
# Replace with your REAL addresses for precise door-to-door travel times
# Use complete addresses including street number, city, state, and ZIP
# Examples:
#   Good: "123 Main St, San Francisco, CA 12345"
#   Good: "123 Main Ave, San Jose, CA 12345"
#   Bad:  "SF" (too vague)
#   Bad:  "Google" (company name, not address)
HOME_ADDRESS=123 Your Street, Your City, State ZIP
WORK_ADDRESS=456 Work Address, Work City, State ZIP

# Caltrain Stations for Transit Routing (defaults work for most Bay Area commuters)
HOME_CALTRAIN_STATION=South San Francisco
WORK_CALTRAIN_STATION=Mountain View

# ================================
# AI Agent
# ================================
# AI Model Configuration
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key  # Optional - only needed if LLM_PROVIDER=anthropic

# LLM Provider Selection
LLM_PROVIDER=openai  # "openai" or "anthropic" - defaults to openai
OPENAI_MODEL=gpt-4o-mini  # OpenAI model to use (default: gpt-4o-mini)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # Anthropic model to use
LLM_TEMPERATURE=0.1  # Temperature for LLM responses (0.0-1.0)

# MCP Server Connection (Your deployed server)
MCP_SERVER_TIMEOUT=30

# Navi (planning orchestrator) — the external service Aura calls for outing/
# weekend plans. NAVI_INTERNAL_AUTH_SECRET must equal Navi's own
# NAVI_INTERNAL_AUTH_SECRET so Navi accepts Aura's X-Internal-Auth header.
NAVI_URL=http://localhost:8100  # prod: https://navi-planner.fly.dev
NAVI_INTERNAL_AUTH_SECRET=your_navi_internal_auth_secret
NAVI_TIMEOUT=60

# Agent Configuration
LOG_LEVEL=INFO
ENABLE_MEMORY=true

# CORS - extra allowed origins (comma-separated, added to defaults)
# Set this to your Vercel deployment URL(s)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ================================
# LangSmith Tracing (Optional)
# ================================
# Sign up at https://smith.langchain.com to get an API key
# Tracing helps debug agent behavior and monitor performance
LANGCHAIN_TRACING_V2=false  # Set to "true" to enable tracing
LANGCHAIN_API_KEY=ls_your_langsmith_api_key
LANGCHAIN_PROJECT=aura  # Project name in LangSmith dashboard
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # Default endpoint

# User Preferences (Customize these!)
USER_NAME=Kevin
USER_LOCATION=San Francisco
DEFAULT_COMMUTE_ORIGIN=Home
DEFAULT_COMMUTE_DESTINATION=Office

# ================================
# UI
# ================================
VITE_ENVIRONMENT=development
VITE_DEBUG=true
VITE_AI_AGENT_API_URL=http://localhost:8001

# ================================
# Auth (Google OAuth, single-user allowlist)
# ================================
# Comma-separated list of Google emails permitted to sign in.
# This is enforced by BOTH the UI (at sign-in time) and the Agent (per-request)
# so removing an email here immediately revokes access.
ALLOWED_EMAILS=you@example.com

# Google OAuth 2.0 credentials (Web application type).
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI (or {origin}/auth/google/callback if unset).
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# REQUIRED in production (or any deployment behind TLS-terminating proxy
# like Vercel/Cloudflare/nginx). In dev it's auto-derived from the request,
# but in production the app fails fast at /auth/google if unset.
# GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# Random secret used to sign the UI's session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_long_random_string

# Shared secret between UI and Agent. The UI sends this on every Agent call;
# the Agent rejects anything without it. Generate with:
#   openssl rand -hex 32
INTERNAL_AUTH_SECRET=replace_me_with_a_long_random_string

# Session cookie Secure flag. Defaults to true (cookie only sent over HTTPS).
# Set to "false" ONLY for local HTTP dev — every deployed env (preview,
# staging, prod) must leave this unset so the cookie never goes over plaintext.
# SESSION_COOKIE_SECURE=false

# ================================
# Infrastructure
# ================================
REDIS_URL=redis://redis:6379
CACHE_TTL=300
